KERNEL_SOURCE=https://github.com/n0n3m4/kernel_samsung_exynos990
KERNEL_SOURCE_BRANCH=main
KERNEL_CONFIG=c1s_defconfig
USE_GCC=false
ENABLE_LXC=true
ENABLE_KERNELSU=true
ADD_OVERLAYFS_CONFIG=true
KERNEL_IMAGE_NAME=Image
ARCH=arm64
ENABLE_CCACHE=true
DISABLE_FST=true
ENABLE_NETHUNTER=false
ENABLE_KALI=false
KERNEL_VERSION=4.19
ENABLE_WIREGUARD=false
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu
DISABLE-LTO=true
DISABLE_CC_WERROR=true
NEED_DTBO=false
BUILD_BOOT_IMG=true
