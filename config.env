CONFIG_ENV=config.env

# [수정] 갤럭시 노트20(스냅드래곤 안드로이드 13) 검증된 커널 소스 주소
KERNEL_SOURCE=https://github.com/Yg0801/android_kernel_samsung_sm8250

# [수정] 안드로이드 13 전용 빌드 브랜치 이름
KERNEL_SOURCE_BRANCH=thirteen

# [수정] 갤럭시 노트20 스냅드래곤 모델용 커널 구성 파일(defconfig)
KERNEL_CONFIG=vendor/canvas_eur_open_defconfig

# [오타 수정] 구글 GCC 4.9 사용 여부 (노트20은 false로 두고 Clang 컴파일러 사용)
USE_GCC=false

# 启用lxc-docker支持，鉴于很多人都不明白，禁用，懂的自己开启。默认支持KernelSU。
ENABLE_LXC=true

# KernelSU相关，默认开启。
ENABLE_KERNELSU=true
ADD_OVERLAYFS_CONFIG=true


# gki内核使用
# KERNELSU_TAG=main
# 非gki内核使用比如4.19,4.14(官方已经停止了非gki的支持，最后版本为0.95)
# KERNELSU_TAG=v0.9.5

# 这块几乎可以不动，KERNEL_IMAGE_NAME可能的取值有Image.gz-dtb,Image.gz,Image等
KERNEL_IMAGE_NAME=Image.gz
ARCH=arm64

# 额外附加命令，默认启用LLVM=1 LLVM_IAS=1 
# EXTRA_CMDS:LD=ld.lld
# EXTRA_CMDS:LLVM=1 LLVM_IAS=1 

# Ccache,可加速二次构建
ENABLE_CCACHE=true

# 关闭fstack-protector-strong(clang-r383902b)
DISABLE_FST=true


# Kali-Nethunter支持，默认关闭，支持内核版本4.4-4.19。
ENABLE_NETHUNTER=false
# 另一个，问题有点多。追求极客，可搞下，build-geek_kernel.yml.bak。
ENABLE_KALI=false
KERNEL_VERSION=4.19 
ENABLE_WIREGUARD=false




# 一般就别动下↓面的内容了，重点改上↑↑↑↑边的就可以
### if your set USE CUSTOM CLANG to false than DO NOT CHANGE CUSTOM CMDS
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-



# Configuration
DISABLE-LTO=true
DISABLE_CC_WERROR=true


# DTBO image
NEED_DTBO=false

# Build boot images
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://raw.githubusercontent.com/tomxi1997/KernelSU-Next-Action/main/boot/boot.img
